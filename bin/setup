#!/usr/bin/env ruby
# frozen_string_literal: true

require 'fileutils'
require 'securerandom'

TARIK_FILE  = '.tarik'
ENV_EXAMPLE = '.env.example'
ENV_FILE    = '.env'

# ── output helpers ─────────────────────────────────────────────────────────────

def banner(text)
  puts "\n\e[1m#{text}\e[0m"
end

def step(label)
  print "  #{label.ljust(32)}"
  $stdout.flush
  yield
  puts "\e[32mdone\e[0m"
rescue => e
  puts "\e[31mfailed\e[0m"
  puts "  \e[31m→ #{e.message}\e[0m"
  exit 1
end

def skip(label, reason)
  puts "  #{label.ljust(32)}\e[33mskipped\e[0m  (#{reason})"
end

# ── prompt helpers ─────────────────────────────────────────────────────────────

def prompt(question, options, default)
  puts "\n  #{question}"
  options.each_with_index do |opt, i|
    marker = opt == default ? '▶' : ' '
    puts "    #{marker} #{i + 1}) #{opt}"
  end
  print "  Choice [#{default}]: "
  $stdout.flush
  input = $stdin.gets&.chomp || ''
  return default if input.empty?

  options.find { |o| o == input } || options[input.to_i - 1] || default
end

def ask_yes_no(question, default)
  label = default ? 'Y/n' : 'y/N'
  print "  #{question} [#{label}]: "
  $stdout.flush
  input = $stdin.gets&.chomp&.downcase || ''
  input.empty? ? default : input.start_with?('y')
end

# ── shell helper ───────────────────────────────────────────────────────────────

def run(cmd, chdir: nil)
  opts = { out: File::NULL, err: File::NULL }
  opts[:chdir] = chdir if chdir
  system(cmd, **opts) or raise "`#{cmd}` exited with an error"
end

# ── config ─────────────────────────────────────────────────────────────────────

def read_config
  return {} unless File.exist?(TARIK_FILE)

  File.readlines(TARIK_FILE).each_with_object({}) do |line, h|
    line.strip!
    next if line.empty? || line.start_with?('#')

    k, v = line.split('=', 2)
    h[k] = v if k && v
  end
end

def write_config(config)
  File.write(TARIK_FILE, config.map { |k, v| "#{k}=#{v}" }.join("\n") + "\n")
end

# ── locale setup ──────────────────────────────────────────────────────────────

def configure_locales(locales)
  return if locales == 'en+ja'

  keep    = locales          # 'en' or 'ja'
  remove  = locales == 'en' ? 'ja' : 'en'

  routing_path = 'frontend/i18n/routing.ts'
  if File.exist?(routing_path)
    File.write(routing_path, <<~TS)
      import { defineRouting } from 'next-intl/routing';

      export const routing = defineRouting({
        locales: ['#{keep}'],
        defaultLocale: '#{keep}',
      });
    TS
    puts "  #{'frontend/i18n/routing.ts'.ljust(32)}\e[32mupdated\e[0m  (#{keep} only)"
  end

  [
    "frontend/i18n/#{remove}.json",
    "api/config/locales/#{remove}.yml",
  ].each do |path|
    next unless File.exist?(path)

    FileUtils.rm(path)
    puts "  #{path.ljust(32)}\e[33mremoved\e[0m   (#{keep} only)"
  end
end

# ── sidekiq / email / storage setup ───────────────────────────────────────────

def note(path, verb, detail)
  puts "  #{path.ljust(32)}\e[32m#{verb}\e[0m  (#{detail})"
end

def uncomment_env_vars(vars, reason)
  content = File.read(ENV_EXAMPLE)
  vars.each { |v| content = content.sub(/^# (#{Regexp.escape(v)}=)/, '\1') }
  File.write(ENV_EXAMPLE, content)
  note(ENV_EXAMPLE, 'updated', reason)
end

def configure_sidekiq(enabled)
  return if enabled

  procfile = 'Procfile.dev'
  if File.exist?(procfile)
    lines = File.readlines(procfile).reject { |l| l.start_with?('worker:') }
    File.write(procfile, lines.join)
    note(procfile, 'updated', 'worker process removed')
  end

  content = File.read(ENV_EXAMPLE)
  File.write(ENV_EXAMPLE, content.sub('ACTIVE_JOB_QUEUE_ADAPTER=sidekiq', 'ACTIVE_JOB_QUEUE_ADAPTER=async'))
  note(ENV_EXAMPLE, 'updated', 'jobs run in-process (:async)')
end

def configure_email(enabled)
  return unless enabled

  uncomment_env_vars(
    %w[SMTP_ADDRESS SMTP_PORT SMTP_USERNAME SMTP_PASSWORD MAILER_FROM MAILER_HOST],
    'SMTP vars enabled — fill in for production'
  )
end

def configure_confirmable(enabled)
  return unless enabled

  path = 'api/app/models/user.rb'
  content = File.read(path)
  File.write(path, content.sub('# :confirmable,', ':confirmable,'))
  note(path, 'updated', 'email verification required on sign-up')
end

def configure_storage(enabled)
  return unless enabled

  gemfile = 'api/Gemfile'
  content = File.read(gemfile)
  File.write(gemfile, content.sub('# gem "aws-sdk-s3"', 'gem "aws-sdk-s3"'))
  note(gemfile, 'updated', 'aws-sdk-s3 enabled')

  storage_yml = 'api/config/storage.yml'
  content = File.read(storage_yml)
  amazon_block = content[/^# amazon:\n(?:^#.*\n)*/]
  if amazon_block
    File.write(storage_yml, content.sub(amazon_block, amazon_block.gsub(/^# /, '')))
    note(storage_yml, 'updated', 'S3 service enabled')
  end

  uncomment_env_vars(
    %w[AWS_ACCESS_KEY_ID AWS_SECRET_ACCESS_KEY AWS_REGION AWS_BUCKET],
    'AWS vars enabled — fill in your bucket'
  )
end

# ── preflight ──────────────────────────────────────────────────────────────────

def check(label, ok, hint, fatal: false)
  if ok
    puts "  #{label.ljust(32)}\e[32mok\e[0m"
  elsif fatal
    puts "  #{label.ljust(32)}\e[31mmissing\e[0m  → #{hint}"
    exit 1
  else
    puts "  #{label.ljust(32)}\e[33mwarning\e[0m  → #{hint}"
  end
end

def preflight
  banner 'Preflight'

  docker_ok = system('docker info', out: File::NULL, err: File::NULL)
  check('Docker daemon', docker_ok, 'start Docker, then re-run bin/setup', fatal: true)

  wanted_ruby = File.exist?('api/.ruby-version') ? File.read('api/.ruby-version').strip : nil
  if wanted_ruby
    check("Ruby #{wanted_ruby}", RUBY_VERSION == wanted_ruby,
          "running #{RUBY_VERSION} — install #{wanted_ruby} with rbenv/mise")
  end

  node_version = `node -v 2>/dev/null`.strip
  check('Node.js >= 24', node_version[/\d+/].to_i >= 24,
        node_version.empty? ? 'node not found — install Node 24 with nvm/mise' : "running #{node_version} — install Node 24 with nvm/mise")

  foreman_ok = !`which foreman 2>/dev/null`.strip.empty?
  check('foreman (for bin/dev)', foreman_ok, 'gem install foreman')
end

# ── main ───────────────────────────────────────────────────────────────────────

puts "\e[1m━━━ tarik setup ━━━\e[0m"

preflight

config = read_config

if config.empty?
  banner 'Configuration (first run)'

  payment = prompt('Payment processor?',  %w[stripe payjp],   'stripe')
  locales = prompt('Supported locales?',  %w[en ja en+ja],    'en+ja')
  sidekiq = ask_yes_no('Include Sidekiq?',                    true)
  email   = ask_yes_no('Include transactional email?',        false)
  confirm = email && ask_yes_no('Require email verification on sign-up?', false)
  storage = ask_yes_no('Include file storage (S3)?',          false)

  config = {
    'payment'     => payment,
    'locales'     => locales,
    'sidekiq'     => sidekiq.to_s,
    'email'       => email.to_s,
    'confirmable' => confirm.to_s,
    'storage'     => storage.to_s
  }
  write_config(config)
  puts "\n  Saved to .tarik\n"

  puts "  #{'AGENTS.md'.ljust(32)}\e[33minitialized from AGENTS.template.md on first git push\e[0m"
  puts "  After that, edit AGENTS.md to describe your project's own conventions."

  configure_locales(config['locales'])
  configure_sidekiq(config['sidekiq'] == 'true')
  configure_email(config['email'] == 'true')
  configure_confirmable(config['confirmable'] == 'true')
  configure_storage(config['storage'] == 'true')

  if config['payment'] == 'payjp'
    puts "\n  \e[33mNote:\e[0m Stripe is what ships wired. To migrate to PAY.JP, follow"
    puts '  docs/payjp-migration.md — it covers service objects, frontend JS, and webhooks.'
  end
else
  banner 'Configuration'
  summary = config.map { |k, v| "#{k}=#{v}" }.join(', ')
  puts "  Found .tarik — skipping prompts"
  puts "  #{summary}"
end

banner 'Setup'

# .env — copy the example and fill in the generatable secrets.
if File.exist?(ENV_FILE)
  skip('.env', 'already exists')
else
  step('.env (with generated secrets)') do
    FileUtils.cp(ENV_EXAMPLE, ENV_FILE)
    env = File.read(ENV_FILE)
    env = env.sub(/^SECRET_KEY_BASE=$/, "SECRET_KEY_BASE=#{SecureRandom.hex(64)}")
    env = env.sub(/^JWT_SECRET=$/,      "JWT_SECRET=#{SecureRandom.hex(64)}")
    File.write(ENV_FILE, env)
  end
end

# Docker
step('Docker (db + redis)') { run('docker compose up -d') }

# Rails (Phase 2+)
if Dir.exist?('api')
  step('Ruby gems')  { run('bundle install', chdir: 'api') }
  step('Database')   { run('bin/rails db:create db:migrate', chdir: 'api') }
  step('Seed data')  { run('bin/rails db:seed', chdir: 'api') }
else
  skip('Ruby gems', 'api/ not yet created')
  skip('Database',  'api/ not yet created')
end

# Next.js (Phase 3+)
if Dir.exist?('frontend')
  step('Node modules') { run('npm install', chdir: 'frontend') }
else
  skip('Node modules', 'frontend/ not yet created')
end

puts "\n\e[1m━━━ Done. Run: bin/dev ━━━\e[0m"
puts '  Works out of the box:  auth (sign-up/sign-in), demo mode (see README)'
puts "  Needs your keys:       Stripe payments — set STRIPE_* in .env\n\n"
