# ── Database ───────────────────────────────────────────────────────────────────
# Matches docker-compose.yml defaults for local development.
DATABASE_URL=postgres://tarik:tarik@localhost:5432/tarik_development

# ── Redis ──────────────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Rails ──────────────────────────────────────────────────────────────────────
RAILS_ENV=development
RAILS_MASTER_KEY=
SECRET_KEY_BASE=

# ── Auth / JWT ─────────────────────────────────────────────────────────────────
# JWT_SECRET: run `rails secret` to generate.
# JWT_EXPIRY: seconds until token expires (86400 = 24 hours).
JWT_SECRET=
JWT_EXPIRY=86400

# ── Stripe ─────────────────────────────────────────────────────────────────────
# Use test-mode keys locally (sk_test_..., pk_test_...).
STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# ── PAY.JP (optional) ──────────────────────────────────────────────────────────
# See docs/payjp-migration.md for switching from Stripe to PAY.JP.
# PAYJP_SECRET_KEY=
# PAYJP_WEBHOOK_SECRET=

# ── Next.js ────────────────────────────────────────────────────────────────────
# NEXT_PUBLIC_* vars are bundled into the browser. Never put secrets here.
NEXT_PUBLIC_API_URL=http://localhost:3001
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Price ID of the subscription plan shown on the subscribe page.
NEXT_PUBLIC_STRIPE_PRICE_ID=price_

# ── Production only ────────────────────────────────────────────────────────────
# API_URL is server-side only — point it at the internal Railway hostname
# so traffic stays within the private network.
# NEXT_PUBLIC_API_URL points to the public URL the browser reaches.
# API_URL=https://tarik-api.railway.internal
