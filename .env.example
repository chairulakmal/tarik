# ══════════════════════════════════════════════════════════════════════════════
# Generated for you — bin/setup fills these in when it creates .env.
# You never need to touch them.
# ══════════════════════════════════════════════════════════════════════════════

SECRET_KEY_BASE=
JWT_SECRET=

# Only needed if you adopt Rails encrypted credentials (bin/rails credentials:edit).
# This app reads all secrets from env vars, so it can stay empty.
RAILS_MASTER_KEY=

# ══════════════════════════════════════════════════════════════════════════════
# Local defaults — match docker-compose.yml; work as-is for development.
# ══════════════════════════════════════════════════════════════════════════════

DATABASE_URL=postgres://tarik:tarik@localhost:5432/tarik_development
REDIS_URL=redis://localhost:6379/0
RAILS_ENV=development

# Seconds until a JWT expires (86400 = 24 hours).
JWT_EXPIRY=86400

# :sidekiq needs a running worker (bin/dev starts one); :async runs jobs in-process.
# bin/setup sets this to async if you opt out of Sidekiq.
ACTIVE_JOB_QUEUE_ADAPTER=sidekiq

NEXT_PUBLIC_API_URL=http://localhost:3001

# Where password-reset / email-confirmation links in emails point.
# Set to your public web URL in production.
FRONTEND_URL=http://localhost:3000

# ══════════════════════════════════════════════════════════════════════════════
# You must obtain these — from the Stripe dashboard (test-mode keys locally:
# sk_test_..., pk_test_...). Or skip Stripe entirely with demo mode below.
# ══════════════════════════════════════════════════════════════════════════════

STRIPE_SECRET_KEY=sk_test_
STRIPE_PUBLISHABLE_KEY=pk_test_
STRIPE_WEBHOOK_SECRET=whsec_

# NEXT_PUBLIC_* vars are bundled into the browser. Never put secrets here.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_
# Price ID of the subscription plan shown on the subscribe page.
NEXT_PUBLIC_STRIPE_PRICE_ID=price_

# ── Demo mode ──────────────────────────────────────────────────────────────────
# Set both to true to run the app without real Stripe keys.
# Payments are simulated — no charges are made.
# Seed a demo user first: cd api && bin/rails db:seed
DEMO_MODE=false
NEXT_PUBLIC_DEMO_MODE=false

# ── Email (optional) ───────────────────────────────────────────────────────────
# Uncommented by bin/setup when transactional email is enabled.
# In development, sent mail opens in your browser (letter_opener) — no SMTP needed.
# In production, SMTP delivery activates when SMTP_ADDRESS is set.
# SMTP_ADDRESS=
# SMTP_PORT=587
# SMTP_USERNAME=
# SMTP_PASSWORD=
# MAILER_FROM=noreply@example.com
# MAILER_HOST=example.com

# ── File storage: S3 (optional) ────────────────────────────────────────────────
# Uncommented by bin/setup when file storage is enabled.
# Development stores files on local disk; set ACTIVE_STORAGE_SERVICE=amazon in
# production (Railway → Variables) to use S3.
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_REGION=us-east-1
# AWS_BUCKET=

# ── PAY.JP (optional) ──────────────────────────────────────────────────────────
# See docs/payjp-migration.md for switching from Stripe to PAY.JP.
# PAYJP_SECRET_KEY=
# PAYJP_WEBHOOK_TOKEN=

# ── Production only ────────────────────────────────────────────────────────────
# API_URL is server-side only — point it at the internal Railway hostname
# so traffic stays within the private network.
# NEXT_PUBLIC_API_URL points to the public URL the browser reaches.
# API_URL=https://tarik-api.railway.internal
